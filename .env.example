# DeepSeek（OpenAI 兼容 Chat Completions）
# 在 https://platform.deepseek.com 申请 API Key
#
# 方式一（推荐本地）：在 mirror 首页底部或 /settings 将 Key 保存到浏览器，
#     请求会通过头 X-DeepSeek-Key 传给本项目的 API Route，再转发到 DeepSeek。
#
# 方式二（仅服务端）：在此文件复制为 .env.local 并填写，勿提交 .env.local。
DEEPSEEK_API_KEY=

# 可选覆盖（默认已指向官方）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
# DEEPSEEK_MODEL=deepseek-chat
